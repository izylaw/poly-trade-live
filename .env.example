POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLYGON_RPC_URL=https://polygon-rpc.com
STARTING_CAPITAL=10
TARGET_BALANCE=1000
TARGET_DAYS=60
PAPER_TRADING=true
# GOAL_START_DATE=2026-03-01T00:00:00+00:00  # leave empty to auto-detect from DB or now
GOAL_START_DATE=
LOG_LEVEL=INFO

# LLM Crypto Strategy (optional — uses Ollama by default)
# Covers all crypto market types: up/down (1h/4h), above/below, price range,
# daily up/down, weekly hit price, monthly hit price.
# Excludes 5m/15m intervals (too fast for local LLM inference).
LLM_ENABLED=false
LLM_BASE_URL=http://100.96.38.49:11434
LLM_MODEL=qwen3.5:27b
# LLM_CONTEXT_SIZE=8192       # Ollama num_ctx — must fit prompt + max_tokens
# LLM_BATCH_SIZE=5            # markets per LLM call (lower = fits context better)
# LLM_MAX_TOKENS=1500         # max output tokens
# LLM_INTERVALS=["1h","4h"]
# LLM_DAILY_LOOKAHEAD_DAYS=5
# LLM_DAILY_CACHE_TTL=1800
